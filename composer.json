{
	"name" : "npsc/hhk",
	"description" : "Healthcare Hospitality Houses Guest Tracking and Reservations",
	"type" : "project",
	"homepage" : "https://nonprofitsoftwarecorp.org",
	"license" : "MIT",
	"authors" : [{
			"name" : "Eric Crane",
			"email" : "ecrane@nonprofitsoftwarecorp.org"
		}, {
			"name" : "Will Ireland",
			"email" : "wireland@nonprofitsoftwarecorp.org"
		}
	],
	"autoload" : {
		"psr-4" : {
			"HHK\\" : "classes/"
		}
	},
	"require" : {
         "php" : "^7.4|^8.1",
        "ext-xml": "*",
		"ext-gd": "*",
		"mk-j/php_xlsxwriter" :"~0.39",
		"phpmailer/phpmailer" : "~6.1",
		"phelium/recaptcha" : "~1.0",
		"chillerlan/php-qrcode" : "~4.3",
		"onelogin/php-saml" : "~4.0",
		"cerdic/css-tidy" : "~2.0",
		"peppeocchi/php-cron-scheduler" : "~4.0",
		"guzzlehttp/guzzle" : "~7.5"
	},
	"scripts" : {
		"pack" : "HHK\\devTools\\Build::run",
		"test:dev" : "phpunit --colors=always --testdox --display-warnings --display-notices --bootstrap tests/envs/dev/bootstrap.php",
		"test:InstallDaily" : "phpunit --colors=always --testdox --bootstrap=tests/envs/dailyPriceModel/bootstrap.php --testsuite installer",
		"test:InstallGuestday" : "phpunit --colors=always --testdox --bootstrap=tests/envs/guestDayPriceModel/bootstrap.php --testsuite installer"

	},
	"require-dev": {
		"phpunit/phpunit": "^10.4"
	}
}
